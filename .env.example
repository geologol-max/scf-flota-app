# ─── FIREBASE ────────────────────────────────────────────────────────────────
# Obtén estos valores desde: Firebase Console → Configuración del Proyecto → Tus apps → Web
# IMPORTANTE: El prefijo VITE_ es necesario para que Vite los exponga al cliente.

VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# ─── GEMINI AI ───────────────────────────────────────────────────────────────
# Obtén tu key desde: aistudio.google.com/apikey
# IMPORTANTE: NO lleva prefijo VITE_ — esta variable es usada SOLO por la
# Serverless Function /api/gemini.ts en el servidor. Nunca queda expuesta en el bundle.

GEMINI_API_KEY="your-gemini-api-key"
